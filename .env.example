# ---------------------------------------------------------------------------
# chronicle — environment configuration (PR0)
# Copy to `.env` and fill in. All-local on the Mac; no remote services.
# ---------------------------------------------------------------------------

# --- Postgres + pgvector (Docker compose service `db`) ---
DATABASE_URL=postgresql://chronicle:chronicle@localhost:5432/chronicle

# --- Embeddings / reranker (used from PR2; dim is LOCKED at 1024 in PR0) ---
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
EMBEDDING_DIM=1024
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# --- Generation backend: Gemini free tier ---
# Get a key from https://aistudio.google.com/apikey
GEN_MODEL=gemini-2.0-flash
GOOGLE_API_KEY=

# --- Judge backend: local Ollama on the Mac ---
# Always read from env; default falls back to localhost so it runs Mac-only.
OLLAMA_BASE_URL=http://localhost:11434
# 3B for building/iterating; swap to qwen2.5:7b for the final eval report.
JUDGE_MODEL=qwen2.5:3b

# --- Langfuse (self-hosted v2, Docker compose service `langfuse`) ---
# Keys are created in the Langfuse UI (http://localhost:3000) after first boot:
#   create a project -> Settings -> API Keys.
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# --- Logging ---
LOG_LEVEL=INFO
